# SMTP Configuration
# Replace these values with your actual SMTP server settings.
# For example, if using Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465 (for SSL) or 587 (for TLS)
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-specific-password

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# The recipient email address as per your requirement
RECEIVER_EMAIL=digitalinfluencerns@gmail.com
